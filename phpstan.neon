includes:
    - tools/phpstan/elegant-object.neon
    - tools/phpstan/disallowed-calls.neon
    - tools/phpstan/disallowed-constructs.neon

parameters:
    level: 9
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # PHPStan standard — dispatch dynamique volontaire vers Webmozart\Assert::method(...)
        -
            message: '#Variable static method call on Webmozart\\Assert\\Assert#'
            path: src/Common/Assert/Assert.php
